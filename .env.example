# taey-presence — environment configuration
#
# Copy to `.env` and adjust. Every value below is also the in-code default, so
# the system runs out-of-the-box against services on localhost with NO auth.
# There are no credentials here by design: this stack assumes a trusted local
# network where Redis / Neo4j / Weaviate run open. Do NOT expose those ports to
# an untrusted network. If you must, put auth in front of them yourself — the
# code passes no credentials.
#
# Nothing here is required. Override only what differs on your machine.

# ── Redis (required service) — task/state bus the workers + dashboard share ──
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ── Model endpoint (required service) — any OpenAI-compatible chat endpoint ──
# Point at your local LLM (vLLM, llama.cpp --api, Ollama's /v1, etc.).
VLLM_URL=http://localhost:8000/v1/chat/completions

# ── Memory search (optional) — hybrid search backend for type-time prefetch ──
# Disable the memory feature by leaving your backend down; the worker degrades.
ISMA_URL=http://localhost:8095

# ── Graph store (optional) — DCM inter-worker state. Degrades to Redis-only ──
# if unreachable. No auth: the driver connects with no credentials.
NEO4J_URI=bolt://localhost:7687

# ── Edge inference host (optional) — a second box serving the model, e.g. an
# NVIDIA Jetson ("THOR_*"). Defaults point back at localhost. The dashboard
# reads telemetry/inference from here when present.
THOR_REDIS_HOST=localhost
THOR_REDIS_PORT=6379
THOR_PROXY=http://localhost:8765
THOR_RAW=http://localhost:8000

# ── Telemetry source (optional) — host the soma daemon polls for GPU/system
# vitals ("SPARK_*" after the NVIDIA DGX Spark tier). localhost = poll self.
SOMA_SPARK_TARGET=localhost
SOMA_SPARK_POLL_INTERVAL=8.0
SOMA_SPARK_CACHE_MAX_AGE=16.0

# ── Face (optional) — resting emoji shown before the model reacts. Empty means
# show nothing until the model freely picks a face (fully dynamic, no preset).
DEFAULT_FACE=
