# taey-presence config. Copy to .env. NO CREDENTIALS — every service runs
# no-auth on your own trusted, isolated network (see README Security).

# --- presence engine (required) ---
MODEL_ENDPOINT=                 # OpenAI-compatible base URL, e.g. http://localhost:8000
MODEL_NAME=                     # set if your server requires a model field

# --- shared Redis (presence engine, soma daemon, dashboard all use it) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# --- optional ---
SEARCH_URL=                     # retrieval endpoint for the memory path; empty = none
NEO4J_BOLT=                     # no-auth bolt URL for DCM publishing; empty = disabled
INSTANCE_ID=presence-0

# --- soma daemon ---
CADENCE_SECONDS=2.718281828     # state-vector publish interval (default e); tune freely
COHERENCE_ALERT_THRESHOLD=0.809 # mean-facet alert floor (default phi/2); tune freely
REMOTE_GPU_TARGET=              # optional ssh target to read GPU from a remote box; empty = local

# --- dashboard web server ---
DASHBOARD_HOST=127.0.0.1        # loopback default — do NOT bind to 0.0.0.0 on an untrusted net
DASHBOARD_PORT=8700
